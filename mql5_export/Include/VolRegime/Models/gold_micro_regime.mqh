double Predict_gold_micro_regime(double &features[]) {
   double sum = 0.0;
   for(int t=0; t<300; t++) {
       int node = gold_micro_regime_TreeStarts[t];
       while(gold_micro_regime_IsLeaf[node] == 0) {
           int f_idx = gold_micro_regime_Feature[node];
           double val = features[f_idx];
           if (val <= gold_micro_regime_Threshold[node]) {
               node = gold_micro_regime_Left[node];
           } else {
               node = gold_micro_regime_Right[node];
           }
       }
       sum += gold_micro_regime_Value[node];
   }
   return 1.0 / (1.0 + MathExp(-sum));
}
