double Predict_nas100_vol_regime_4h(double &features[]) {
   double sum = 0.0;
   double scaled_features[59];
   for(int i=0; i<59; i++) {
       scaled_features[i] = (features[i] - nas100_vol_regime_4h_ScalerMean[i]) / nas100_vol_regime_4h_ScalerScale[i];
   }
   for(int t=0; t<210; t++) {
       int node = nas100_vol_regime_4h_TreeStarts[t];
       while(nas100_vol_regime_4h_IsLeaf[node] == 0) {
           int f_idx = nas100_vol_regime_4h_Feature[node];
           double val = scaled_features[f_idx];
           if (val <= nas100_vol_regime_4h_Threshold[node]) {
               node = nas100_vol_regime_4h_Left[node];
           } else {
               node = nas100_vol_regime_4h_Right[node];
           }
       }
       sum += nas100_vol_regime_4h_Value[node];
   }
   return 1.0 / (1.0 + MathExp(-sum));
}
