double Predict_gold_speed_tape_v2(double &features[]) {
   double sum = 0.0;
   for(int t=0; t<300; t++) {
       int node = gold_speed_tape_v2_TreeStarts[t];
       while(gold_speed_tape_v2_IsLeaf[node] == 0) {
           int f_idx = gold_speed_tape_v2_Feature[node];
           double val = features[f_idx];
           if (val <= gold_speed_tape_v2_Threshold[node]) {
               node = gold_speed_tape_v2_Left[node];
           } else {
               node = gold_speed_tape_v2_Right[node];
           }
       }
       sum += gold_speed_tape_v2_Value[node];
   }
   return 1.0 / (1.0 + MathExp(-sum));
}
