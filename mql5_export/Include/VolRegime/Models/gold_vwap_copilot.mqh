   for(int t=0; t<200; t++) {
       int node = gold_vwap_copilot_TreeStarts[t];
       while(gold_vwap_copilot_IsLeaf[node] == 0) {
           int f_idx = gold_vwap_copilot_Feature[node];
           double val = features[f_idx];
           if (val <= gold_vwap_copilot_Threshold[node]) {
               node = gold_vwap_copilot_Left[node];
           } else {
               node = gold_vwap_copilot_Right[node];
           }
       }
       sum += gold_vwap_copilot_Value[node];
   }
   return 1.0 / (1.0 + MathExp(-sum));
}
