double Predict_nas100_vol_regime_1h(double &features[]) {
   double sum = 0.0;
   double scaled_features[59];
   for(int i=0; i<59; i++) {
       scaled_features[i] = (features[i] - nas100_vol_regime_1h_ScalerMean[i]) / nas100_vol_regime_1h_ScalerScale[i];
   }
   for(int t=0; t<400; t++) {
       int node = nas100_vol_regime_1h_TreeStarts[t];
       while(nas100_vol_regime_1h_IsLeaf[node] == 0) {
           int f_idx = nas100_vol_regime_1h_Feature[node];
           double val = scaled_features[f_idx];
           if (val <= nas100_vol_regime_1h_Threshold[node]) {
               node = nas100_vol_regime_1h_Left[node];
           } else {
               node = nas100_vol_regime_1h_Right[node];
           }
       }
       sum += nas100_vol_regime_1h_Value[node];
   }
   return 1.0 / (1.0 + MathExp(-sum));
}
