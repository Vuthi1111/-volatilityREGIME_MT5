double Predict_nas100_speed_tape_v2(double &features[]) {
   double sum = 0.0;
   for(int t=0; t<300; t++) {
       int node = nas100_speed_tape_v2_TreeStarts[t];
       while(nas100_speed_tape_v2_IsLeaf[node] == 0) {
           int f_idx = nas100_speed_tape_v2_Feature[node];
           double val = features[f_idx];
           if (val <= nas100_speed_tape_v2_Threshold[node]) {
               node = nas100_speed_tape_v2_Left[node];
           } else {
               node = nas100_speed_tape_v2_Right[node];
           }
       }
       sum += nas100_speed_tape_v2_Value[node];
   }
   return 1.0 / (1.0 + MathExp(-sum));
}
