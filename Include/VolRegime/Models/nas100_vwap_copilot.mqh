double Predict_nas100_vwap_copilot(double &features[]) {
   double sum = 0.0;
   for(int t=0; t<200; t++) {
       int node = nas100_vwap_copilot_TreeStarts[t];
       while(nas100_vwap_copilot_IsLeaf[node] == 0) {
           int f_idx = nas100_vwap_copilot_Feature[node];
           double val = features[f_idx];
           if (val <= nas100_vwap_copilot_Threshold[node]) {
               node = nas100_vwap_copilot_Left[node];
           } else {
               node = nas100_vwap_copilot_Right[node];
           }
       }
       sum += nas100_vwap_copilot_Value[node];
   }
   return 1.0 / (1.0 + MathExp(-sum));
}
