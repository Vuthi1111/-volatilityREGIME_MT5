double Predict_nas100_micro_regime(double &features[]) {
   double sum = 0.0;
   for(int t=0; t<300; t++) {
       int node = nas100_micro_regime_TreeStarts[t];
       while(nas100_micro_regime_IsLeaf[node] == 0) {
           int f_idx = nas100_micro_regime_Feature[node];
           double val = features[f_idx];
           if (val <= nas100_micro_regime_Threshold[node]) {
               node = nas100_micro_regime_Left[node];
           } else {
               node = nas100_micro_regime_Right[node];
           }
       }
       sum += nas100_micro_regime_Value[node];
   }
   return 1.0 / (1.0 + MathExp(-sum));
}
